{
  "name": "3d-design-editor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "electron": "electron .",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "build:electron": "cross-env VITE_BASE=./ vite build",
    "build:win": "cross-env VITE_BASE=./ vite build && electron-builder --win"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "blockly": "^11.2.2",
    "peerjs": "^1.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.168.0",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.10",
    "three-stdlib": "^2.29.9",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "gh-pages": "^6.3.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.imaginarium.editor",
    "productName": "Imaginarium",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "win": { "target": ["nsis", "portable"] }
  }
}
